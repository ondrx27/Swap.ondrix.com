# Transak API Configuration
# Get your API key from https://dashboard.transak.com/
VITE_TRANSAK_API_KEY=your_transak_api_key_here
# Environment: STAGING (for testing) or PRODUCTION (after KYB approval)
VITE_TRANSAK_ENVIRONMENT=STAGING

# For STAGING (testing):
# - Use staging API key from dashboard
# - No real transactions, only demo orders
# - Available immediately after registration

# For PRODUCTION (live transactions):
# - Requires KYB (Know Your Business) approval
# - Use production API key
# - Set VITE_TRANSAK_ENVIRONMENT=PRODUCTION

# MoonPay API Configuration
# Get your API key from https://www.moonpay.com/dashboard
VITE_MOONPAY_API_KEY=your_moonpay_api_key_here
VITE_MOONPAY_SANDBOX=true

# Note:
# - VITE_ prefix is required for Vite to expose variables to the frontend
# - Never commit .env files with real API keys to version control
# - Copy this file to .env and fill in your actual keys
