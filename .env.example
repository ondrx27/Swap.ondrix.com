# Jupiter API Configuration (optional)
VITE_JUPITER_API_KEY=your_jupiter_api_key_here

# Helius RPC (optional, for local dev only — production uses /api/rpc proxy)
# VITE_HELIUS_API_KEY=your_helius_api_key_here

# Note:
# - VITE_ prefix is required for Vite to expose variables to the frontend
# - Never commit .env files with real API keys to version control
# - Copy this file to .env and fill in your actual keys
